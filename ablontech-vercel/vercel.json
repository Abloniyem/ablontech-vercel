{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)",      "dest": "/api/$1" },
    { "src": "/css/(.*)",      "dest": "/public/css/$1" },
    { "src": "/js/(.*)",       "dest": "/public/js/$1" },
    { "src": "/assets/(.*)",   "dest": "/public/assets/$1" },
    { "src": "/admin/login",   "dest": "/api/admin-login.js" },
    { "src": "/admin/logout",  "dest": "/api/admin-logout.js" },
    { "src": "/admin",         "dest": "/api/admin-page.js" },
    { "src": "/",              "dest": "/public/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    }
  ]
}
